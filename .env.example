# OpenAI-Hub (https://www.openai-hub.com/) — OpenAI-compatible relay
# 推荐直接配置这个。
OPENAI_HUB_API_KEY=sk-your-key-here
OPENAI_HUB_BASE_URL=https://api.openai-hub.com/v1
OPENAI_HUB_MODEL=gpt-4o
OPENAI_HUB_MODEL_MINI=gpt-4o-mini
HARNESS_DEFAULT_PROVIDER=openai-hub

# 可选别名 HARNESS_DEFAULT_PROVIDER=hub-openai 同样可用
